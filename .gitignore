# Machine-specific Claude Code overrides
.claude/settings.local.json

# Single-use guard override marker (SDO-012) — ephemeral, never committed
.claude/.guard-override.json

# Checkpoint reminder throttle marker (SDO-018) — ephemeral, never committed
.claude/.checkpoint-reminder-state

# Source files — stored in Google Drive, not git
WORKSPACE/SYSTEM_SOURCES/
DOMAINS/*/RAW/

# Binary file types (safety net)
*.pdf
!WORKSPACE/ARTIFACTS/*.pdf
*.jpg
*.jpeg
*.png
*.gif
*.mp4
*.mp3
*.zip
*.docx
*.xlsx
*.pptx
